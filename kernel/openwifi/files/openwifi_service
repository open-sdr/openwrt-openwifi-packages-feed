#!/bin/sh /etc/rc.common

START=19

OPENWIFI_DIR=/root/openwifi

create_sdr0(){
  # Check if sdr0 already exists
  ip link show sdr0 >/dev/null 2>&1 && return 0

  # Find the openwifi phy by its known MAC prefix
  for phy in /sys/class/ieee80211/*/; do
      MAC=$(cat ${phy}macaddress 2>/dev/null)
      case "$MAC" in
          66:55:44:33:22:*)
              PHYNAME=$(basename $phy)
              logger -t openwifi "Creating sdr0 on $PHYNAME"
              iw phy $PHYNAME interface add sdr0 type managed
              ip link set sdr0 up
              return 0
              ;;
      esac
  done

  logger -t openwifi "WARNING: openwifi phy not found by MAC prefix"
  return 1
}

boot() {
	logger -t openwifi "OPENWIFI SERVICE BOOT"

	logger -t openwifi "Loading kernel modules"
	cd $OPENWIFI_DIR
	sh wgd.sh

  logger -t openwifi "Add default interface sdr0"
	create_sdr0

	logger -t openwifi "OPENWIFI DONE LOADING"
}
